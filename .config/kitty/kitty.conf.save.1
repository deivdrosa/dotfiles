color6  #c7c7c7
color7  #d6d6d6 
foreground #b3b3b3
background #0b0c10

cursor #ff3b5c

selection_background #ff3b5c
selection_foreground #0b0c10

# base escura
color0  #0b0c10
color8  #1a1c22

# vermelho (principal + hover)
color1  #ff3b5c
color9  #ff5c73

# neutros controlados (reduzidos pra não “quebrar o tema”)
color2  #8a8a8a
color3  #9a9a9a
color4  #a6a6a6
color5  #b3b3b3
color6  #c2c2c2
color7  #d0d0d0
font_family JetBrainsMono Nerd Font
font_size 12.5

background_opacity 0.10

window_padding_width 14

cursor_shape block
cursor_blink_interval 0

enable_audio_bell no

scrollback_lines 10000

# URLs clicáveis
detect_urls yes

# remove poluição visual
hide_window_decorations yes

# espaço respirável
line_height 1.2
include catppuccin-mocha.conf
include theme.conf

