foreground #b3b3b3
background #0b0c10

cursor #ff3b5c

selection_background #ff3b5c
selection_foreground #0b0c10

# base escura
color0  #0b0c10
color8  #1a1c22

# vermelho (principal + hover levemente mais vivo)
color1  #ff3b5c
color9  #ff4a66

