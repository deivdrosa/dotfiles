nt_family JetBrainsMono Nerd Font
font_size 12.5

background_opacity 0.10

window_padding_width 14

cursor_shape block
cursor_blink_interval 0

enable_audio_bell no

scrollback_lines 10000

# URLs clicáveis
detect_urls yes

# remove poluição visual
hide_window_decorations yes

# espaço respirável
line_height 1.2
include catppuccin-mocha.conf
include theme.conf

foreground #c9c9c9
background #0f0f12
cursor #ff4d6d

color1 #ff4d6d
color9 #ff6b81
